# Frontend runtime/build configuration
# Copy to .env.local (for development) or .env.production (for server build).

# Required for Gemini Live API calls from browser
VITE_GEMINI_API_KEY=

# Optional: absolute URL of backend API in production (without trailing slash)
# Example: https://api.your-domain.uz
VITE_API_BASE_URL=

# Development-only options
# Enable HTTPS for local microphone permissions (true/false)
VITE_DEV_HTTPS=true

# If your backend runs on another host in development, set proxy target
# Example: https://localhost:8000
VITE_DEV_API_PROXY_TARGET=
